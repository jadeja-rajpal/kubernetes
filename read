      labels:
        app: nginx-secret

    spec:
      containers:
      - name: nginx
        image: nginx

        env:
        - name: DB_USERNAME
          valueFrom:
            secretKeyRef:
              name: db-secret
              key: username

        - name: DB_PASSWORD
          valueFrom:
            secretKeyRef:
              name: db-secret
